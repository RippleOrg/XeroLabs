{
  "name": "xero-labs",
  "version": "1.0.0",
  "description": "On-chain NAV oracle and yield aggregator for tokenized RWAs on HashKey Chain",
  "private": true,
  "workspaces": [
    "sdk",
    "offchain",
    "frontend"
  ],
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:oracle": "hardhat test test/XeroOracle.test.ts",
    "test:vault": "hardhat test test/XeroVault.test.ts",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network hashkeyTestnet",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network hashkeyMainnet",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "lint": "eslint 'sdk/src/**/*.ts' 'offchain/src/**/*.ts' 'scripts/**/*.ts' 'test/**/*.ts'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.3.0",
    "dotenv": "^16.6.1",
    "hardhat": "^2.28.6",
    "solhint": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
